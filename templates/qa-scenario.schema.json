{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/miniprogram-design-qa/qa-scenario.schema.json",
  "title": "Miniprogram Design QA Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "route",
    "viewport",
    "readySignal",
    "capture"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "object",
      "default": {},
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    },
    "fixture": {
      "type": "string"
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "deviceScaleFactor"
      ],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "deviceScaleFactor": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "readySignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "selector",
            "text",
            "network-idle",
            "data-stable"
          ]
        },
        "value": {
          "type": "string"
        },
        "timeoutMs": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "stableMs": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "viewport",
            "fullPage"
          ]
        },
        "devtools": {
          "type": "boolean"
        },
        "navigationMode": {
          "type": "string",
          "enum": [
            "relaunch",
            "navigate"
          ]
        },
        "fullPage": {
          "type": "boolean"
        },
        "segments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "segmentSelectors": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "prepareCommand": {
          "type": "string"
        },
        "helperCommand": {
          "type": "string"
        },
        "manualFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manualDirectory": {
          "type": "string"
        }
      }
    },
    "compare": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "includeAA": {
          "type": "boolean"
        },
        "minHotspotArea": {
          "type": "number",
          "minimum": 1
        },
        "minHotspotPixels": {
          "type": "number",
          "minimum": 1
        },
        "maxHotspots": {
          "type": "number",
          "minimum": 1
        },
        "hotspotMergeDistance": {
          "type": "number",
          "minimum": 0
        },
        "exportHotspotCrops": {
          "type": "boolean"
        },
        "segmentThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "perSegmentThresholds": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "segmentDesignImages": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "figmaFileKey": {
          "type": "string",
          "description": "Metadata only. The built-in pipeline does not export screenshots from Figma."
        },
        "figmaNodeId": {
          "type": "string",
          "description": "Metadata only. The built-in pipeline does not export screenshots from Figma."
        },
        "designImagePath": {
          "type": "string",
          "description": "Local design image path consumed by the built-in compare pipeline."
        },
        "baselineImagePath": {
          "type": "string",
          "description": "Local baseline image path consumed by the built-in compare pipeline."
        }
      }
    },
    "ignoreRegions": {
      "type": "array",
      "description": "Optional masking selector list. The built-in compare pipeline applies masks when capture metadata can resolve selector geometry; fallback/manual paths may emit warnings or provide reduced masking behavior.",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "description": "Human-readable scenario notes for agents and engineers.",
      "items": {
        "type": "string"
      }
    }
  }
}
